---
import type { BusinessContent } from "@homepage/content";

type Props = {
  business: BusinessContent["business"];
  navigation: BusinessContent["navigation"];
};

const { business, navigation } = Astro.props;
---

<header class="site-header">
  <a class="brand" href="#top" aria-label={`${business.name} トップ`}>
    {
      business.logo ? (
        <img src={business.logo.src} alt={business.logo.alt} />
      ) : (
        <>
          <span class="brand__mark" aria-hidden="true">
            B
          </span>
          <span>
            <strong>BINITA</strong>
            <small>{business.name}</small>
          </span>
        </>
      )
    }
  </a>
  <nav aria-label="メインナビゲーション">
    {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>

<style>
  .site-header {
    align-items: center;
    background: var(--color-primary);
    border-bottom: 4px solid var(--color-accent);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    left: 0;
    padding: 0.85rem clamp(1rem, 4vw, 2rem);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
  }

  .brand {
    align-items: center;
    color: var(--color-primary-text);
    display: inline-flex;
    gap: 0.65rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .brand img {
    display: block;
    height: 4rem;
    width: auto;
  }

  .brand strong {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.35rem;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  .brand small {
    color: color-mix(
      in srgb,
      var(--color-primary-text) 86%,
      var(--color-accent)
    );
    display: block;
    font-size: 0.78rem;
    font-weight: 800;
    margin-top: 0.15rem;
  }

  .brand__mark {
    background: var(--color-accent);
    border: 2px solid
      color-mix(in srgb, var(--color-primary-text) 88%, var(--color-accent));
    border-radius: 4px;
    color: var(--color-text);
    display: grid;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 900;
    height: 2.1rem;
    place-items: center;
    width: 2.1rem;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1rem;
    justify-content: flex-end;
  }

  nav a {
    color: var(--color-primary-text);
    font-size: 0.94rem;
    font-weight: 850;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 720px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    nav {
      justify-content: flex-start;
    }

    .brand img {
      height: 3.3rem;
    }
  }
</style>
