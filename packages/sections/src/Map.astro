---
import type { BusinessContent } from "@homepage/content";

type Props = {
  contact: BusinessContent["contact"];
};

const { contact } = Astro.props;
---

{contact.mapEmbedUrl && (
  <section class="map" aria-label="地図">
    <iframe
      src={contact.mapEmbedUrl}
      title={`${contact.address}の地図`}
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    />
  </section>
)}

<style>
  .map {
    border-top: 1px solid var(--color-border);
  }

  iframe {
    border: 0;
    display: block;
    height: 420px;
    width: 100%;
  }
</style>
