---
import Section from "@homepage/ui/Section.astro";
import type { BusinessContent } from "@homepage/content";

type Props = {
  posts: NonNullable<BusinessContent["posts"]>;
};

const { posts } = Astro.props;
---

{
  posts.length > 0 && (
    <Section id="news" eyebrow="お知らせ" title="新着情報">
      <div class="news">
        {posts.map((post) => (
          <article>
            <time datetime={post.date}>{post.date}</time>
            <h3>{post.title}</h3>
            <p>{post.text}</p>
          </article>
        ))}
      </div>
    </Section>
  )
}

<style>
  .news {
    display: grid;
    gap: 1rem;
  }

  article {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.2rem;
  }

  time {
    color: var(--color-primary);
    display: block;
    font-size: 0.88rem;
    font-weight: 850;
    margin-bottom: 0.4rem;
  }

  h3 {
    margin: 0 0 0.45rem;
  }

  p {
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
  }
</style>
