---
import type { BusinessContent } from "@homepage/content";

type Props = {
  business: BusinessContent["business"];
  navigation: BusinessContent["navigation"];
};

const { business, navigation } = Astro.props;
const year = new Date().getFullYear();
---

<footer>
  <strong>{business.name}</strong>
  <nav aria-label="フッターナビゲーション">
    {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
  <span>&copy; {year} {business.name}</span>
</footer>

<style>
  footer {
    align-items: center;
    background: var(--color-text);
    color: white;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr auto 1fr;
    padding: 1.5rem clamp(1rem, 4vw, 2rem);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
  }

  a,
  span {
    color: rgba(255, 255, 255, 0.78);
  }

  a {
    text-decoration: none;
  }

  span {
    justify-self: end;
  }

  @media (max-width: 760px) {
    footer {
      justify-items: start;
      grid-template-columns: 1fr;
    }

    nav {
      justify-content: flex-start;
    }

    span {
      justify-self: start;
    }
  }
</style>
