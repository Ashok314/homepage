---
import Button from "@homepage/ui/Button.astro";
import type { BusinessContent } from "@homepage/content";

type Props = {
  hero: BusinessContent["hero"];
};

const { hero } = Astro.props;
---

<section class="hero" id="top">
  <div class="hero__content">
    <p>{hero.eyebrow}</p>
    <h1>{hero.title}</h1>
    <span>{hero.text}</span>
    <div class="hero__actions">
      <Button href={hero.primaryAction.href}>{hero.primaryAction.label}</Button>
      <Button href={hero.secondaryAction.href} variant="secondary">{hero.secondaryAction.label}</Button>
    </div>
  </div>
  <div class="hero__media">
    <img src={hero.image.src} alt={hero.image.alt} loading="eager" />
  </div>
</section>

<style>
  .hero {
    background:
      linear-gradient(90deg, rgba(155, 28, 18, 0.08), transparent 42%),
      var(--color-background);
    border-bottom: 1px solid var(--color-border);
    display: grid;
    gap: clamp(1.25rem, 5vw, 3.5rem);
    grid-template-columns: minmax(0, 0.9fr) minmax(300px, 1.1fr);
    min-height: auto;
    padding: clamp(2rem, 7vw, 5rem) clamp(1rem, 6vw, 4rem);
    position: relative;
  }

  .hero__media {
    align-self: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: 0 16px 34px rgba(43, 23, 13, 0.14);
    padding: 0.55rem;
  }

  img {
    aspect-ratio: 96 / 50;
    border-radius: calc(var(--radius) - 2px);
    display: block;
    height: auto;
    object-fit: contain;
    width: 100%;
  }

  .hero__content {
    align-self: center;
    color: var(--color-text);
    max-width: 640px;
  }

  p {
    color: var(--color-primary);
    font-size: 0.9rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0 0 0.8rem;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 8vw, 6rem);
    letter-spacing: 0.04em;
    line-height: 1;
    margin: 0;
    text-shadow: 0 2px 0 color-mix(in srgb, var(--color-accent) 32%, transparent);
  }

  span {
    display: block;
    color: var(--color-muted);
    font-size: clamp(1.05rem, 2vw, 1.22rem);
    line-height: 1.7;
    margin-top: 1.25rem;
    max-width: 54ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.75rem;
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }
</style>
