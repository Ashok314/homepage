---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteContent, theme } from "../../content/site";

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}clients/binita/archive/${path}`;
---

<BaseLayout content={siteContent} theme={theme}>
  <div
    class="binita-page"
    style={`--binita-title-bg: url("${asset("all/titleback02.png")}"); --binita-footer-bg: url("${asset("all/contentsback03.png")}")`}
  >
    <a class="skip-link" href="#main">本文へ移動</a>

    <header class="archive-header" id="top">
      <div class="top-line">
        {siteContent.business.topLine}
      </div>
      <nav class="archive-nav" aria-label="メインナビゲーション">
        {
          siteContent.navigation.map((nav) => (
            <a href={nav.href}>{nav.label}</a>
          ))
        }
      </nav>
    </header>

    <main id="main">
      {
        siteContent.banner && (
          <section class="banner-wrap" aria-label="お知らせバナー">
            {siteContent.banner.collapsible ? (
              <details class="banner" open={siteContent.banner.defaultOpen}>
                <summary>
                  <span class="banner-title">{siteContent.banner.title}</span>
                  <span class="banner-toggle" aria-hidden="true" />
                </summary>
                <div class="banner-body">
                  {siteContent.banner.items?.length ? (
                    <div class="banner-list">
                      {siteContent.banner.items.map((item) => (
                        <a
                          class="banner-item"
                          href={item.href}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {item.logo && (
                            <span class="banner-item__logo">
                              <img
                                src={`${base}${item.logo.src}`}
                                alt={item.logo.alt}
                                width="56"
                                height="56"
                              />
                            </span>
                          )}
                          <span class="banner-item__content">
                            <strong>{item.title}</strong>
                            <span>{item.text}</span>
                          </span>
                          <span class="banner-item__cta">
                            {item.linkLabel ?? "詳しく見る"}
                          </span>
                        </a>
                      ))}
                    </div>
                  ) : (
                    <>
                      <p>{siteContent.banner.text}</p>
                      {siteContent.banner.href && (
                        <a
                          href={siteContent.banner.href}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {siteContent.banner.linkLabel ?? "詳しく見る"}
                        </a>
                      )}
                    </>
                  )}
                </div>
              </details>
            ) : (
              <div class="banner">
                <div class="banner-body">
                  <p>
                    <strong>{siteContent.banner.title}</strong>{" "}
                    {siteContent.banner.text}
                  </p>
                  <a
                    href={siteContent.banner.href}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {siteContent.banner.linkLabel ?? "詳しく見る"}
                  </a>
                </div>
              </div>
            )}
          </section>
        )
      }
      <div class="brand-logo">
        <a href="#top" aria-label="BINITA トップ">
          <img src={asset("all/logo.png")} alt="BINITA(ビニタ)" />
        </a>
      </div>

      <section class="main-visual" aria-label="メインビジュアル">
        <div class="main-visual__slides">
          {
            siteContent.hero.slides?.map((visual, index) => (
              <img
                class:list={[
                  "main-visual__slide",
                  index === 0 && "main-visual__slide--first"
                ]}
                src={
                  visual.src.startsWith("http")
                    ? visual.src
                    : `${base}${visual.src}`
                }
                alt={visual.alt}
                loading={index === 0 ? "eager" : "lazy"}
              />
            ))
          }
        </div>
      </section>

      <div class="page-shell">
        <article class="content">
          <section class="box intro">
            <h2><span>{siteContent.about.title}</span></h2>
            <div class="intro-grid">
              <img
                src={siteContent.about.image.src.startsWith("http")
                  ? siteContent.about.image.src
                  : `${base}${siteContent.about.image.src}`}
                alt={siteContent.about.image.alt}
              />
              <div>
                <h3>{siteContent.about.subtitle}</h3>
                <p>
                  {
                    siteContent.about.text.split("\n").map((line) => (
                      <>
                        {line}
                        <br />
                      </>
                    ))
                  }
                </p>
              </div>
            </div>
          </section>

          {
            siteContent.webOrder && (
              <section id="order" class="box order">
                <h2>
                  <span>{siteContent.webOrder.title}</span>
                </h2>
                <div class="order-links">
                  {siteContent.webOrder.links.map((link) =>
                    link.href ? (
                      <a
                        href={link.href}
                        aria-label={`${link.label}で注文`}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <span class="service-logo">
                          {link.logo ? (
                            <img
                              src={`${base}${link.logo.src}`}
                              alt={link.logo.alt}
                              width="64"
                              height="64"
                            />
                          ) : (
                            link.logoText
                          )}
                        </span>
                        <span>{link.label}</span>
                        {link.rating && (
                          <span class="order-rating">{link.rating}</span>
                        )}
                        {link.campaign && (
                          <span class="order-campaign">{link.campaign}</span>
                        )}
                      </a>
                    ) : (
                      <span class="order-link" aria-disabled="true">
                        <span class="service-logo">
                          {link.logo ? (
                            <img
                              src={`${base}${link.logo.src}`}
                              alt={link.logo.alt}
                              width="64"
                              height="64"
                            />
                          ) : (
                            link.logoText
                          )}
                        </span>
                        <span>{link.label}</span>
                        {link.rating && (
                          <span class="order-rating">{link.rating}</span>
                        )}
                        {link.campaign && (
                          <span class="order-campaign">{link.campaign}</span>
                        )}
                      </span>
                    )
                  )}
                </div>
              </section>
            )
          }

          <section id="news" class="box">
            <h2><span>お知らせ</span></h2>
            <div class="news-list">
              {
                siteContent.posts?.map((post) => (
                  <article>
                    <time datetime={post.date}>{post.date}</time>
                    <h3>{post.title}</h3>
                    <p>{post.text}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section id="lunch" class="box">
            <h2>
              <span>{siteContent.menu.groups?.[0]?.title || "ランチ"}</span>
            </h2>
            {
              siteContent.menu.notice && (
                <p class="notice">{siteContent.menu.notice}</p>
              )
            }
            <div class="menu-grid">
              {
                siteContent.menu.groups?.slice(0, 2).map((card) => (
                  <article class="menu-card">
                    {card.image && (
                      <img
                        src={
                          card.image.src.startsWith("http")
                            ? card.image.src
                            : `${base}${card.image.src}`
                        }
                        alt={card.image.alt}
                      />
                    )}
                    <div>
                      <h3>{card.description || card.title}</h3>
                      <strong>{card.price}</strong>
                      <ul>
                        {card.items.map((item) => (
                          <li>{item.name}</li>
                        ))}
                      </ul>
                    </div>
                  </article>
                ))
              }
            </div>
          </section>

          <section id="dinner" class="box">
            <h2>
              <span>{siteContent.menu.groups?.[2]?.title || "ディナー"}</span>
            </h2>
            <div class="menu-grid">
              {
                siteContent.menu.groups?.slice(2, 4).map((card) => (
                  <article class="menu-card">
                    {card.image && (
                      <img
                        src={
                          card.image.src.startsWith("http")
                            ? card.image.src
                            : `${base}${card.image.src}`
                        }
                        alt={card.image.alt}
                      />
                    )}
                    <div>
                      <h3>{card.description || card.title}</h3>
                      <strong>{card.price}</strong>
                      <ul>
                        {card.items.map((item) => (
                          <li>{item.name}</li>
                        ))}
                      </ul>
                    </div>
                  </article>
                ))
              }
            </div>
            <div class="sub-menu">
              {
                siteContent.menu.groups?.slice(4, 7).map((card) => (
                  <article>
                    {card.image && (
                      <img
                        src={
                          card.image.src.startsWith("http")
                            ? card.image.src
                            : `${base}${card.image.src}`
                        }
                        alt={card.image.alt ?? card.title}
                      />
                    )}
                    <h3>{card.title}</h3>
                    <p>{card.description}</p>
                    <strong>{card.price}</strong>
                  </article>
                ))
              }
            </div>
          </section>

          <section id="drink" class="box">
            <h2><span>ドリンク</span></h2>
            <div class="two-col">
              {
                siteContent.menu.groups?.slice(7, 9).map((group) => (
                  <div>
                    <h3>{group.title}</h3>
                    <p>{group.description}</p>
                    <strong>{group.price}</strong>
                  </div>
                ))
              }
            </div>
          </section>

          {
            siteContent.party && (
              <section id="party" class="box party">
                <h2>
                  <span>{siteContent.party.title}</span>
                </h2>
                <h3>{siteContent.party.subtitle}</h3>
                <p>{siteContent.party.description}</p>
                <p class="notice">{siteContent.party.notice}</p>
                <div class="party-summary">
                  <img
                    src={
                      siteContent.party.summary.image.src.startsWith("http")
                        ? siteContent.party.summary.image.src
                        : `${base}${siteContent.party.summary.image.src}`
                    }
                    alt={siteContent.party.summary.image.alt}
                  />
                  <div>
                    <h3>{siteContent.party.summary.title}</h3>
                    {siteContent.party.summary.text.map((t) => (
                      <p set:html={t} />
                    ))}
                  </div>
                </div>
                <div class="party-courses">
                  {siteContent.party.courses.map((course) => (
                    <article>
                      <h3>{course.title}</h3>
                      <strong>{course.price}</strong>
                      <dl>
                        <dt>料理内容</dt>
                        <dd>{course.food}</dd>
                        <dt>飲物内容</dt>
                        <dd>{course.drink}</dd>
                      </dl>
                    </article>
                  ))}
                </div>
              </section>
            )
          }

          <section id="access" class="box">
            <h2><span>アクセス</span></h2>
            <h3>{siteContent.business.name}</h3>
            <dl class="access-list">
              <dt>住所</dt>
              <dd>{siteContent.contact.address}</dd>
              <dt>TEL</dt>
              <dd>
                <a href={`tel:${siteContent.contact.phone.replace(/-/g, "")}`}
                  >{siteContent.contact.phone}</a
                >
              </dd>
              <dt>営業時間</dt>
              <dd>{siteContent.contact.hours.join(" / ")}</dd>
              {
                siteContent.contact.details?.map((detail) => {
                  // Only split by space if the detail doesn't contain a colon. If it's something like "定休日 年中無休", split it.
                  const match = detail.match(/^(\S+)\s+(.+)$/);
                  if (match) {
                    return (
                      <>
                        <dt>{match[1]}</dt>
                        <dd>{match[2]}</dd>
                      </>
                    );
                  }
                  return (
                    <>
                      <dt>備考</dt>
                      <dd>{detail}</dd>
                    </>
                  );
                })
              }
            </dl>
            {
              siteContent.contact.photos && (
                <div class="access-photos">
                  {siteContent.contact.photos.map((photo) => (
                    <img
                      src={
                        photo.src.startsWith("http")
                          ? photo.src
                          : `${base}${photo.src}`
                      }
                      alt={photo.alt}
                    />
                  ))}
                </div>
              )
            }
            {
              siteContent.contact.mapEmbedUrl && (
                <iframe
                  class="map-frame"
                  src={siteContent.contact.mapEmbedUrl}
                  title={`${siteContent.business.name} Google マップ`}
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                />
              )
            }
            {
              siteContent.paymentMethods && (
                <section id="payment" class="box">
                  <h2>
                    <span>{siteContent.paymentMethods.title}</span>
                  </h2>
                  <div class="payment-methods">
                    <p>{siteContent.paymentMethods.description}</p>
                    <ul>
                      {siteContent.paymentMethods.methods.map((method) => (
                        <li>
                          <strong>{method.label}:</strong> {method.items}
                        </li>
                      ))}
                    </ul>
                  </div>
                </section>
              )
            }

            {
              siteContent.reviews && (
                <section id="reviews" class="box">
                  <h2>
                    <span>{siteContent.reviews.title}</span>
                  </h2>

                  <div class="reviews-card">
                    <div class="stars">★★★★★</div>
                    <p class="reviews-text">{siteContent.reviews.text}</p>

                    <div class="reviews-actions">
                      {siteContent.reviews.readReviewsLink && (
                        <a
                          href={siteContent.reviews.readReviewsLink}
                          class="btn-read-reviews"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {siteContent.reviews.readReviewsLabel ||
                            "口コミを読む"}
                        </a>
                      )}
                      {siteContent.reviews.getReviewsLink && (
                        <a
                          href={siteContent.reviews.getReviewsLink}
                          class="btn-get-reviews"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {siteContent.reviews.getReviewsLabel ||
                            "レビューを書く"}
                        </a>
                      )}
                    </div>
                  </div>
                </section>
              )
            }
          </section>
        </article>
      </div>

      <footer class="archive-footer">
        {
          siteContent.business.logo && (
            <img
              src={
                siteContent.business.logo.src.startsWith("http")
                  ? siteContent.business.logo.src
                  : `${base}${siteContent.business.logo.src}`
              }
              alt={siteContent.business.logo.alt}
            />
          )
        }
        <p>{siteContent.business.footerText}</p>
        <small
          >&copy; {new Date().getFullYear()} {siteContent.business.name}</small
        >
      </footer>
    </main>
  </div>

  <style>
    .archive-header {
      background: var(--binita-footer-bg), #fffbf2;
    }

    .top-line {
      background: #f2630c;
      color: #fff;
      font-size: 0.82rem;
      font-weight: 700;
      padding: 0.32rem 1rem;
      text-align: center;
    }

    .archive-nav a {
      color: #b53e00;
      font-weight: 800;
      text-decoration: none;
    }

    .archive-nav {
      background: #fff;
      border-bottom: 5px solid #f2630c;
      border-top: 1px solid #f2630c;
      display: flex;
      flex-wrap: wrap;
      gap: 0;
      justify-content: center;
    }

    .archive-nav a {
      border-left: 1px solid #ffdba6;
      color: #b53e00;
      min-width: 120px;
      padding: 0.62rem 1.1rem;
      text-align: center;
    }

    .archive-nav a:last-child {
      border-right: 1px solid #ffdba6;
    }

    .brand-logo {
      background: var(--binita-footer-bg), #fffbf2;
      padding: 1rem 1rem 0.45rem;
      text-align: center;
    }

    .banner-wrap {
      margin: 1.25rem auto 0;
      max-width: 1080px;
      padding: 0 1rem 0.85rem;
    }

    .banner {
      background: #fff9e9;
      border: 1px solid #f2c66d;
      border-radius: 8px;
      box-shadow: 0 4px 14px rgba(92, 43, 8, 0.08);
      color: #5b2d06;
      overflow: hidden;
    }

    .banner summary {
      align-items: center;
      cursor: pointer;
      display: flex;
      gap: 1rem;
      justify-content: space-between;
      list-style: none;
      padding: 0.95rem 1.1rem;
    }

    .banner summary::-webkit-details-marker {
      display: none;
    }

    .banner-title {
      font-size: 1.05rem;
      font-weight: 900;
      letter-spacing: 0.04em;
    }

    .banner-toggle::before {
      content: "+";
      display: inline-block;
      font-size: 1.3rem;
      font-weight: 700;
      line-height: 1;
    }

    .banner[open] .banner-toggle::before {
      content: "-";
    }

    .banner-body {
      padding: 0 1.1rem 1rem;
    }

    .banner-list {
      display: grid;
      gap: 0.55rem;
    }

    .banner-item {
      align-items: center;
      background: transparent;
      border: 0;
      border-radius: 0;
      color: inherit;
      display: grid;
      gap: 0.65rem;
      grid-template-columns: 40px minmax(0, 1fr) auto;
      padding: 0.35rem 0;
      text-decoration: none;
      width: 100%;
    }

    .banner-item:hover {
      opacity: 0.88;
    }

    .banner-item__logo {
      align-items: center;
      background: transparent;
      border-radius: 0;
      display: inline-flex;
      height: 40px;
      justify-content: center;
      justify-self: center;
      overflow: hidden;
      width: 40px;
    }

    .banner-item__logo img {
      display: block;
      height: auto;
      max-height: 28px;
      max-width: 40px;
      width: auto;
    }

    .banner-item__content {
      align-items: baseline;
      display: flex;
      gap: 0.45rem;
      min-width: 0;
      white-space: nowrap;
    }

    .banner-item__content strong {
      font-size: 0.94rem;
      flex: 0 0 auto;
    }

    .banner-item__content span {
      font-size: 0.92rem;
      font-weight: 600;
      line-height: 1.2;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .banner-item__cta {
      background: transparent;
      border: 0;
      border-radius: 0;
      color: #b53e00;
      display: inline-flex;
      font-size: 0.85rem;
      font-weight: 800;
      justify-self: end;
      margin-left: auto;
      padding: 0;
      text-align: center;
      white-space: nowrap;
    }

    .banner-body p {
      margin: 0;
      font-weight: 700;
    }

    .banner-body a {
      background: transparent;
      border-radius: 0;
      display: inline-flex;
      font-weight: 800;
      padding: 0;
      text-decoration: none;
    }

    .banner-body a:hover {
      text-decoration: underline;
    }

    .brand-logo img {
      display: block;
      height: auto;
      margin: 0 auto;
      max-width: min(300px, 70vw);
      width: 300px;
    }

    .main-visual {
      background: transparent;
      padding: 0.35rem 1rem 0;
    }

    .main-visual__slides {
      aspect-ratio: 940 / 500;
      margin: 0 auto;
      max-width: 960px;
      overflow: hidden;
      position: relative;
      width: 100%;
    }

    .main-visual__slide {
      animation: binitaMainVisual 24s infinite both;
      display: block;
      height: 100%;
      inset: 0;
      object-fit: cover;
      opacity: 0;
      position: absolute;
      width: 100%;
      z-index: 0;
    }

    .main-visual__slide:nth-child(2) {
      animation-delay: 6s;
    }

    .main-visual__slide:nth-child(3) {
      animation-delay: 12s;
    }

    .main-visual__slide:nth-child(4) {
      animation-delay: 18s;
    }

    .main-visual__slide--first {
      opacity: 1;
    }

    @keyframes binitaMainVisual {
      0%,
      22% {
        opacity: 1;
        z-index: 1;
      }

      25%,
      97% {
        opacity: 0;
        z-index: 0;
      }

      100% {
        opacity: 1;
        z-index: 1;
      }
    }

    .page-shell {
      margin: 0 auto;
      max-width: 1100px;
      padding: 1.5rem 1rem 3rem;
    }

    .content {
      display: grid;
      gap: 1.25rem;
      align-content: start;
    }

    .box {
      background: #fff;
      border: 1px solid #44880b;
      border-radius: 3px;
      padding: 1rem;
    }

    h2 {
      background-image: var(--binita-title-bg);
      background-position: center;
      border: 1px solid #ffdba6;
      color: #fff;
      font-family: var(--font-heading);
      font-size: 1.55rem;
      margin: 0 0 1rem;
      padding: 0.7rem 1rem;
      text-align: center;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.55);
    }

    h2 span {
      color: #fff;
    }

    h3 {
      color: #290e00;
      margin: 0 0 0.65rem;
    }

    p {
      color: #4d2c19;
      line-height: 1.8;
    }

    .notice {
      color: #b53e00;
      font-weight: 800;
    }

    .intro-grid {
      align-items: center;
      display: grid;
      gap: 1rem;
      grid-template-columns: 240px minmax(0, 1fr);
    }

    .intro-grid img {
      width: 100%;
    }

    .news-list,
    .menu-grid,
    .sub-menu,
    .two-col {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .news-list article,
    .menu-card,
    .sub-menu article,
    .two-col > div {
      background: #fff;
      border: 1px dashed #44880b;
      padding: 0.9rem;
    }

    .menu-card {
      display: grid;
      gap: 0.8rem;
      grid-template-columns: 140px minmax(0, 1fr);
    }

    .menu-card img,
    .sub-menu img,
    .party img {
      border: 4px solid #fff;
      box-shadow: 0 0 0 1px #44880b;
      display: block;
      height: auto;
      width: 100%;
    }

    strong,
    time {
      color: #b53e00;
      font-weight: 900;
    }

    ul {
      margin: 0.65rem 0 0;
      padding-left: 1.1rem;
    }

    li {
      line-height: 1.7;
    }

    .access-list {
      display: grid;
      grid-template-columns: 9rem minmax(0, 1fr);
      margin: 0;
    }

    dt,
    dd {
      border-bottom: 1px dashed #44880b;
      margin: 0;
      padding: 0.65rem;
    }

    dt {
      background: #ffdba6;
      font-weight: 900;
    }

    .access-photos {
      display: grid;
      gap: 0.7rem;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin-top: 1rem;
    }

    .access-photos img {
      display: block;
      height: auto;
      width: 100%;
    }

    .order-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
      justify-content: center;
    }

    .map-frame {
      border: 1px solid #44880b;
      display: block;
      height: 320px;
      margin-top: 1rem;
