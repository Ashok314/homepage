---
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hello World</title>
  </head>
  <body>
    <main>
      <p class="eyebrow">Monorepo test app</p>
      <h1>Hello World</h1>
      <p>This app is deployed under <strong>{base}</strong>.</p>
    </main>
  </body>
</html>

<style>
  :global(html) {
    background: #f5f7fb;
    color: #18212f;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: grid;
    place-items: center;
  }

  main {
    background: #fff;
    border: 1px solid #d7e0ef;
    border-radius: 16px;
    box-shadow: 0 18px 40px rgba(24, 33, 47, 0.08);
    max-width: 34rem;
    padding: 2rem;
    text-align: center;
  }

  .eyebrow {
    color: #5d6b82;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2rem, 6vw, 3.4rem);
    line-height: 1;
    margin: 0 0 1rem;
  }

  p {
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0;
  }
</style>
