---
import { homeContent } from "../content/site";

type AppInfo = {
  name: string;
  slug: string;
  devUrl?: string;
  category: string;
  description: string;
  tags: string[];
};

const appModules = import.meta.glob<{ appInfo: AppInfo }>(
  "../../../*/app.config.ts",
  {
    eager: true
  }
);

const apps = Object.values(appModules)
  .map((module) => module.appInfo)
  .sort((left, right) => left.name.localeCompare(right.name));
const categories = [...new Set(apps.map((app) => app.category))];
const footerAuthors = homeContent.footer.authors.map((author) => ({
  ...author,
  url: "url" in author ? author.url : undefined
}));
const year = new Date().getFullYear();

const base = import.meta.env.BASE_URL;
const resolveHref = (app: (typeof apps)[number]) =>
  import.meta.env.DEV ? app.devUrl : `${base}${app.slug}/`;
---

<!doctype html>
<html lang={homeContent.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{homeContent.meta.title}</title>
    <meta name="description" content={homeContent.meta.description} />
  </head>
  <body>
    <main class="shell">
      <header class="hero">
        <p class="eyebrow">{homeContent.hero.eyebrow}</p>
        <h1>{homeContent.hero.title}</h1>
        <p class="intro">{homeContent.hero.intro}</p>
        <div class="hero-stats" aria-label={homeContent.hero.statsLabel}>
          <div>
            <strong>{apps.length}</strong>
            <span>{homeContent.hero.appsLabel}</span>
          </div>
          <div>
            <strong>{categories.length}</strong>
            <span>{homeContent.hero.categoriesLabel}</span>
          </div>
        </div>
        <label class="search">
          <span>{homeContent.hero.searchLabel}</span>
          <input
            id="app-search"
            type="search"
            placeholder={homeContent.hero.searchPlaceholder}
          />
        </label>
      </header>

      <section class="results-bar" aria-live="polite">
        <p
          id="results-count"
          data-showing-all-prefix={homeContent.results.showingAllPrefix}
          data-showing-prefix={homeContent.results.showingPrefix}
          data-apps-label={homeContent.results.appsLabel}
          data-result-singular={homeContent.results.resultSingular}
          data-result-plural={homeContent.results.resultPlural}
        >
          {homeContent.results.showingAllPrefix}
          {apps.length}
          {homeContent.results.appsLabel}
        </p>
        <ul
          class="category-list"
          aria-label={homeContent.results.availableCategoriesLabel}
        >
          {categories.map((category) => <li>{category}</li>)}
        </ul>
      </section>

      <section
        class="app-list"
        aria-label={homeContent.results.availableAppsLabel}
      >
        {
          apps.map((app) => (
            <a
              class="app-card"
              href={resolveHref(app)}
              data-name={app.name.toLowerCase()}
              data-category={app.category.toLowerCase()}
              data-tags={app.tags.join(" ").toLowerCase()}
            >
              <div>
                <p class="app-category">{app.category}</p>
                <h2>{app.name}</h2>
                <p>{app.description}</p>
              </div>
              <ul class="tags" aria-label={`${app.name} tags`}>
                {app.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            </a>
          ))
        }
      </section>

      <p id="no-results" class="no-results" hidden>
        {homeContent.results.noResults}
      </p>
    </main>

    <footer class="site-footer">
      <div class="footer-brand">
        <strong>{homeContent.footer.brand}</strong>
      </div>
      <div class="footer-authors" aria-label="By section">
        <span class="footer-authors-label">By</span>
        <ul>
          {
            footerAuthors.map((author) => (
              <li>
                {author.url ? (
                  <a href={author.url} target="_blank" rel="noreferrer">
                    {author.name}
                  </a>
                ) : (
                  <strong class="footer-author-name">{author.name}</strong>
                )}
                <span>{author.role}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <span class="footer-copyright"
        >&copy; {year} {homeContent.footer.brand}</span
      >
    </footer>

    <script is:inline>
      const input = document.querySelector("#app-search");
      const cards = Array.from(document.querySelectorAll(".app-card"));
      const resultsCount = document.querySelector("#results-count");
      const noResults = document.querySelector("#no-results");
      const copy = {
        showingAllPrefix:
          resultsCount?.dataset.showingAllPrefix ?? "Showing all",
        showingPrefix: resultsCount?.dataset.showingPrefix ?? "Showing",
        appsLabel: resultsCount?.dataset.appsLabel ?? "apps",
        resultSingular: resultsCount?.dataset.resultSingular ?? "result",
        resultPlural: resultsCount?.dataset.resultPlural ?? "results"
      };

      const updateResults = (query) => {
        let visibleCount = 0;

        for (const card of cards) {
          const haystack = [
            card.dataset.name,
            card.dataset.category,
            card.dataset.tags
          ].join(" ");
          const isVisible = query.length === 0 || haystack.includes(query);
          card.hidden = !isVisible;
          if (isVisible) visibleCount += 1;
        }

        if (resultsCount) {
          resultsCount.textContent =
            query.length === 0
              ? `${copy.showingAllPrefix} ${visibleCount} ${copy.appsLabel}`
              : `${copy.showingPrefix} ${visibleCount} ${visibleCount === 1 ? copy.resultSingular : copy.resultPlural}`;
        }

        if (noResults) {
          noResults.hidden = visibleCount > 0;
        }
      };

      input?.addEventListener("input", (event) => {
        const query = event.currentTarget.value.trim().toLowerCase();
        updateResults(query);
      });

      updateResults("");
    </script>
  </body>
</html>

<style>
  :global(html) {
    background:
      radial-gradient(circle at top, rgba(86, 141, 255, 0.12), transparent 34%),
      linear-gradient(180deg, #f7f9fc 0%, #eef2f7 100%);
    color: #172033;
    font-family:
      "Avenir Next", "Segoe UI", ui-sans-serif, system-ui, sans-serif;
  }

  body {
    display: flex;
    flex-direction: column;
    margin: 0;
    min-height: 100vh;
  }

  .shell {
    flex: 1;
    margin: 0 auto;
    max-width: 1080px;
    padding: 3rem 1.25rem 2.5rem;
    width: 100%;
  }

  .hero {
    align-items: center;
    display: grid;
    justify-items: center;
    margin-bottom: 2rem;
    text-align: center;
  }

  .eyebrow {
    color: #607089;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin: 0;
  }

  .intro {
    color: #4e5e76;
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 1rem 0 0;
    max-width: 42rem;
  }

  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .hero-stats div {
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid #d9e1ee;
    border-radius: 999px;
    display: inline-flex;
    gap: 0.45rem;
    padding: 0.65rem 0.9rem;
  }

  .hero-stats strong {
    color: #172033;
  }

  .hero-stats span {
    color: #607089;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .search {
    display: grid;
    gap: 0.45rem;
    margin-top: 1.5rem;
    max-width: 30rem;
    width: min(100%, 30rem);
  }

  .search span {
    font-size: 0.92rem;
    font-weight: 700;
  }

  .search input {
    appearance: none;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid #cad4e3;
    border-radius: 14px;
    font: inherit;
    padding: 0.9rem 1rem;
  }

  .app-list {
    display: grid;
    gap: 1rem;
    margin: 0 auto;
    max-width: 56rem;
  }

  .results-bar {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    justify-content: space-between;
    margin: 0 auto 1rem;
    max-width: 56rem;
  }

  .results-bar p {
    color: #4e5e76;
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0;
  }

  .category-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .category-list li {
    background: transparent;
    border: 1px solid #cad4e3;
    border-radius: 999px;
    color: #4e5e76;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.4rem 0.7rem;
  }

  .app-card {
    align-items: start;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid #d9e1ee;
    border-radius: 20px;
    box-shadow: 0 18px 42px rgba(19, 30, 48, 0.06);
    color: inherit;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr) auto;
    padding: 1.25rem;
    text-decoration: none;
  }

  .app-card:hover {
    border-color: #9fb3d1;
    transform: translateY(-2px);
  }

  .app-card[hidden],
  .no-results[hidden] {
    display: none !important;
  }

  .app-category {
    color: #607089;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    margin: 0 0 0.4rem;
    text-transform: uppercase;
  }

  h2 {
    font-size: 1.4rem;
    margin: 0;
  }

  .app-card p:last-child {
    color: #4e5e76;
    line-height: 1.6;
    margin: 0.6rem 0 0;
    max-width: 42rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: flex-end;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tags li {
    background: #eef3fb;
    border-radius: 999px;
    color: #314764;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.4rem 0.7rem;
  }

  .no-results {
    color: #4e5e76;
    font-size: 0.98rem;
    font-weight: 700;
    margin: 1rem auto 0;
    max-width: 56rem;
    text-align: center;
  }

  .site-footer {
    align-items: start;
    background: #172033;
    color: #f7f9fc;
    display: grid;
    gap: 1rem 1.5rem;
    grid-template-columns: minmax(0, 1fr) auto auto;
    padding: 1.5rem max(1.25rem, calc((100vw - 1080px) / 2 + 1.25rem));
  }

  .footer-brand {
    display: grid;
  }

  .site-footer strong {
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-authors {
    align-items: center;
    display: inline-flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .footer-authors-label {
    color: rgba(247, 249, 252, 0.62);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .footer-authors ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-authors li {
    align-items: center;
    display: inline-flex;
    gap: 0.45rem;
  }

  .footer-authors a {
    color: #f7f9fc;
    font-weight: 700;
    text-decoration: none;
  }

  .footer-author-name {
    color: #f7f9fc;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: normal;
    text-transform: none;
  }

  .footer-authors li span {
    color: rgba(247, 249, 252, 0.7);
    font-size: 0.9rem;
  }

  .footer-copyright {
    align-self: center;
    color: rgba(247, 249, 252, 0.78);
    margin: 0;
  }

  @media (max-width: 720px) {
    .results-bar {
      align-items: flex-start;
      flex-direction: column;
    }

    .app-card {
      grid-template-columns: 1fr;
    }

    .tags {
      justify-content: flex-start;
    }

    .site-footer {
      grid-template-columns: 1fr;
      padding-inline: 1.25rem;
    }
  }
</style>
